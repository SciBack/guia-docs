# ============================================================
# GUIA Node — variables de entorno (.env.example)
# Copiar a .env y completar los valores reales.
# NUNCA commitear el .env con secretos.
# ============================================================

# ── Modo LLM ─────────────────────────────────────────────────
# LOCAL  : Ollama para todo (datos sensibles, campus)
# HYBRID : Ollama intent/clasificación + Claude síntesis (default)
# CLOUD  : Claude para todo (demos, alta calidad)
GUIA_LLM_MODE=HYBRID

# ── Entorno ───────────────────────────────────────────────────
ENVIRONMENT=development
GUIA_BASE_URL=https://guia.upeu.edu.pe
LOG_LEVEL=INFO

# ── Fuentes de datos DSpace ───────────────────────────────────
DSPACE_BASE_URL=https://repositorio.upeu.edu.pe
DSPACE_OAI_PMH_URL=https://repositorio.upeu.edu.pe/oai/request
# Credenciales DSpace REST (opcional, solo si se usa submit/update)
DSPACE_EMAIL=
DSPACE_PASSWORD=

# ── Fuentes de datos OJS ─────────────────────────────────────
OJS_BASE_URL=https://revistas.upeu.edu.pe
OJS_OAI_PMH_URL=https://revistas.upeu.edu.pe/index.php/index/oai
OJS_API_TOKEN=

# ── ALICIA/CONCYTEC ──────────────────────────────────────────
ALICIA_OAI_URL=https://alicia.concytec.gob.pe/vufind/OAI/Server
ALICIA_METADATA_PREFIX=oai_dc
# ALICIA_SET_SPEC=upeu  # opcional: filtrar por institución

# ── LLM Cloud (sciback-llm-claude) ───────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6

# ── LLM Local (sciback-llm-ollama) ───────────────────────────
OLLAMA_BASE_URL=http://ia.guia.upeu.edu.pe
OLLAMA_API_KEY=
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_DEFAULT_EMBEDDING_MODEL=multilingual-e5-large-instruct

# ── Embeddings E5 (sciback-embeddings-e5) ────────────────────
E5_OLLAMA_BASE_URL=http://ia.guia.upeu.edu.pe
E5_OLLAMA_API_KEY=
E5_MODEL=multilingual-e5-large-instruct
E5_EMBEDDING_DIM=1024

# ── Vector store (sciback-vectorstore-pgvector) ───────────────
# Nota: requiere psycopg3 driver (postgresql+psycopg://)
PGVECTOR_DATABASE_URL=postgresql+psycopg://guia:changeme@postgres:5432/guia_db
PGVECTOR_TABLE_NAME=guia_vectors
PGVECTOR_EMBEDDING_DIM=1024

# ── PostgreSQL (para docker compose) ─────────────────────────
POSTGRES_DB=guia_db
POSTGRES_USER=guia
POSTGRES_PASSWORD=changeme

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# ── Auth / Keycloak ──────────────────────────────────────────
KEYCLOAK_URL=https://keycloak.guia.sciback.com
KEYCLOAK_REALM=upeu
KEYCLOAK_CLIENT_ID=guia-node
KEYCLOAK_CLIENT_SECRET=changeme

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_RATE_LIMIT=10

# ── GROBID (Sprint 0.4) ───────────────────────────────────────
GROBID_BASE_URL=http://grobid:8070

# ── Scheduler ────────────────────────────────────────────────
HARVEST_CRON=0 2 * * *
# S3 backup (placeholder Sprint 0.7)
AWS_S3_BACKUP_BUCKET=
AWS_REGION=us-east-1
